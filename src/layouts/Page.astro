---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  subtitle?: string;
  description: string;
}

const { title, subtitle, description } = Astro.props;
---

<Layout title={title} description={description}>
  <main class="main">
    <article>
      <div>
        <h1>
          {subtitle && <span>{subtitle}</span>}
          <span>{title}</span>
        </h1>
      </div>
      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</Layout>
