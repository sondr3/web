{
  "name": "web",
  "private": true,
  "license": "MIT",
  "type": "module",
  "stylelint": "@sondr3/stylelint",
  "scripts": {
    "dev": "svelte-kit dev",
    "build": "svelte-kit build",
    "preview": "svelte-kit preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --check --ignore-path .gitignore --plugin-search-dir=. .",
    "format:fix": "prettier --write --ignore-path .gitignore --plugin-search-dir=. .",
    "lint": "eslint --cache --ignore-path .gitignore .",
    "lint:fix": "eslint --fix --cache --ignore-path .gitignore .",
    "style": "stylelint --config .stylelintrc.cjs src",
    "style:fix": "stylelint --fix --config .stylelintrc.cjs src",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@sondr3/eslint-config": "0.6.0",
    "@sondr3/prettier": "0.5.1",
    "@sondr3/stylelint": "0.10.1",
    "@sondr3/tsconfig": "0.7.0",
    "@sveltejs/adapter-vercel": "next",
    "@sveltejs/kit": "next",
    "@types/node": "15.12.5",
    "@types/react": "17.0.11",
    "@types/react-dom": "17.0.8",
    "@typescript-eslint/eslint-plugin": "4.28.0",
    "@typescript-eslint/parser": "4.28.0",
    "eslint": "7.29.0",
    "eslint-config-next": "11.0.1",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "3.4.0",
    "eslint-plugin-simple-import-sort": "7.0.0",
    "eslint-plugin-svelte3": "3.2.0",
    "eslint-plugin-tsdoc": "0.2.14",
    "husky": "6.0.0",
    "lint-staged": "11.0.0",
    "prettier": "2.3.2",
    "prettier-eslint": "12.0.0",
    "prettier-plugin-svelte": "2.3.1",
    "sass": "1.35.1",
    "stylelint": "13.13.1",
    "svelte": "3.38.3",
    "svelte-check": "2.2.0",
    "svelte-preprocess": "4.7.3",
    "tslib": "2.3.0",
    "typescript": "4.3.4"
  },
  "lint-staged": {
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{svelte,ts}": [
      "eslint cache --fix",
      "prettier --write"
    ]
  }
}
