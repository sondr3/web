  "license": "WTFPL",
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "astro": "7.0.7",
    "astro-compressor": "next",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "sitemap": "9.0.1",
    "stylelint": "17.14.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "6.0.3"
  },
  "stylelint": {
    "extends": [
      "stylelint-prettier/recommended"
    ]
  }
